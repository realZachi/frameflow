{
  "name": "frameflow",
  "description": "An AI-first, local-first canvas editor for editable App Store screenshot sets.",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "packageManager": "bun@1.3.9",
  "overrides": {
    "@hono/node-server": "2.0.10"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview",
    "structure": "bun scripts/check-structure.ts",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "bun run lint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit": "bun audit",
    "check": "bun run structure && bun run lint && bun run test:coverage && bun run build && bun run audit"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "^2.0.16",
    "@ai-sdk/anthropic": "^4.0.18",
    "@ai-sdk/google": "^4.0.23",
    "@ai-sdk/openai": "^4.0.19",
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/bricolage-grotesque": "latest",
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource-variable/instrument-sans": "latest",
    "@fontsource-variable/manrope": "^5.3.0",
    "@fontsource-variable/syne": "^5.3.0",
    "@fontsource/bebas-neue": "^5.3.0",
    "@fontsource/caveat": "^5.3.0",
    "@fontsource/dm-serif-display": "^5.3.0",
    "@fontsource/fraunces": "latest",
    "@fontsource/playfair-display": "^5.3.0",
    "@fontsource/space-mono": "^5.3.0",
    "@hugeicons/core-free-icons": "^4.2.3",
    "@hugeicons/react": "^1.1.9",
    "@tailwindcss/vite": "^4.3.3",
    "ai": "^7.0.31",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "latest",
    "jszip": "latest",
    "react": "latest",
    "react-dom": "latest",
    "shadcn": "^4.14.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "latest",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "jsdom": "^29.1.1",
    "typescript": "5.9.3",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vitest": "^4.1.6"
  }
}
