# Optional: configure one or more providers for AI-assisted generation.
# Copy this file to .env.local and restart the app after changing a value.
# These VITE_* values are intentionally browser-visible and are suitable only
# for the local Frameflow app. Never commit .env.local or deploy a keyed build.
VITE_MOONSHOT_API_KEY=
VITE_GOOGLE_GENERATIVE_AI_API_KEY=
VITE_ALIBABA_API_KEY=
VITE_OPENAI_API_KEY=
VITE_ANTHROPIC_API_KEY=
